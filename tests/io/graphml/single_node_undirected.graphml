<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/graphml">
  <key id="vcolor" for="node" attr.name="color" attr.type="int"><default>0</default></key>
  <key id="ecolor" for="edge" attr.name="color" attr.type="int"><default>0</default></key>
  <graph id="G" edgedefault="undirected">
    <node id="n0"><data key="vcolor">0</data></node>
  </graph>
</graphml>
